# ==================================
# DATABASE CONFIGURATION
# ==================================
# Create a fresh Neon database for the portfolio demo, then paste the URL below.

# Neon Database (PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host/database
VITE_NEON_DATABASE_URL=

# ==================================
# SUPABASE CONFIGURATION
# ==================================
# Create a fresh Supabase project for storage/auth assets used by the demo.

VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ==================================
# APP CONFIGURATION
# ==================================

VITE_APP_URL=http://localhost:8896
APP_URL=http://localhost:8896

# ==================================
# NETLIFY CONFIGURATION
# ==================================
# Create a new Netlify site for this repo and keep the API URL pointed at Netlify Functions.

# API URL for Netlify Functions
VITE_API_URL=/.netlify/functions
VITE_DEPLOYMENT_PLATFORM=netlify

NODE_ENV=development

# ==================================
# SESSION & JWT
# ==================================

SESSION_SECRET=your-random-session-secret-change-this
JWT_SECRET=your-random-jwt-secret-change-this
JWT_EXPIRES_IN=7d

# ==================================
# EMAIL NOTIFICATION CONFIGURATION
# ==================================

# Email Provider: 'console', 'smtp', 'sendgrid', 'ses'
# - 'console': Log emails to console (development only)
# - 'smtp': Use custom SMTP server (Gmail, Outlook, etc.)
# - 'sendgrid': Use SendGrid API
# - 'ses': Use AWS SES
EMAIL_PROVIDER=console

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Email Sender Information
EMAIL_FROM=noreply@company.com
EMAIL_FROM_NAME=Portfolio Leave Demo
EMAIL_REPLY_TO=hr@company.com

# ==================================
# SLACK INTEGRATION (Optional)
# ==================================

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ==================================
# COMPANY SETTINGS
# ==================================

COMPANY_NAME=Portfolio Demo Company
WORK_DAYS_PER_WEEK=5
WEEKEND_DAYS=0,6

# ==================================
# DEVELOPMENT & DEBUGGING
# ==================================

# Enable debug mode (development only)
DEBUG=false
LOG_LEVEL=info
