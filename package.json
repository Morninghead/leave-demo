{
  "name": "leave-management-system",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "netlify dev",
    "dev:netlify:full": "netlify dev --functions=netlify/functions",
    "dev:netlify:core": "netlify dev --functions=netlify/functions-core",
    "build": "vite build",
    "build:netlify": "npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:db": "node test-neon-connection.js",
    "test:seed": "node test-seed-data.js",
    "test:storage": "node test-supabase-storage.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:accessibility": "playwright test --config=playwright-accessibility.config.ts",
    "test:performance": "playwright test --config=playwright-performance.config.ts",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:api": "playwright test --config=playwright-api.config.ts",
    "backfill:approval-shadow:dry": "node scripts/backfill-approval-shadow.mjs",
    "backfill:approval-shadow": "node scripts/backfill-approval-shadow.mjs --apply",
    "backfill:approval-notifications:dry": "node scripts/backfill-approval-notifications.mjs",
    "backfill:approval-notifications": "node scripts/backfill-approval-notifications.mjs --apply",
    "remediate:legacy-approvals": "node scripts/remediate-legacy-approvals.cjs",
    "remediate:legacy-approvals:apply": "node scripts/remediate-legacy-approvals.cjs --apply --map .tmp/legacy-approval-map.json",
    "generate:web-push-vapid": "node scripts/generate-web-push-vapid.mjs",
    "test:all": "npm run test && npm run test:e2e && npm run test:accessibility",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test:coverage",
    "security:audit": "npm audit --audit-level=high",
    "security:snyk": "snyk test",
    "security:deps": "npm ci",
    "performance:lighthouse": "lhci autorun",
    "docs:api": "swagger-jsdoc -d swagger -c jsdoc.conf -i src src/**/*.ts",
    "docs:serve": "http-server swagger",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:deploy": "storybook-to-github-pages",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "npm run validate"
  },
  "dependencies": {
    "@fontsource/sarabun": "^5.2.8",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@line/bot-sdk": "^10.6.0",
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/functions": "^5.1.5",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.2",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "i18next": "^25.10.9",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.6.0",
    "netlify-cli": "^24.5.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "glob": "^11.0.0",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/plugin-nextjs": "^5.15.9",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-mdx-gfm": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@storybook/test-runner": "^0.24.3",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "baseline-browser-mapping": "^2.10.10",
    "c8": "^11.0.0",
    "chromatic": "^16.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sinon": "^21.0.3",
    "snyk": "^1.1303.2",
    "storybook": "^10.3.3",
    "storybook-deployer": "^2.8.12",
    "supertest": "^7.2.2",
    "swagger-jsdoc": "^6.2.8",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1",
    "vitest-dom": "^0.1.1",
    "vitest-mock-extended": "^3.1.0"
  }
}
